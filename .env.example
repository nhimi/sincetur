# =============================================================================
# .env.example — Template de variáveis de ambiente
# Copie este ficheiro para .env e preencha os valores:
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Aplicação
# ---------------------------------------------------------------------------
NODE_ENV=production

# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=gere_com_openssl_rand_base64_32

# URL de acesso público (ex: https://seudominio.com ou http://IP:81)
NEXTAUTH_URL=http://localhost:81

# ---------------------------------------------------------------------------
# Base de dados (PostgreSQL)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://sincetur_user:password@localhost:5432/sincetur

# ---------------------------------------------------------------------------
# Docker Compose — password do PostgreSQL
# ---------------------------------------------------------------------------
DB_PASSWORD=password_segura_aqui
